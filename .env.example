# ============================================
# CIER PLATFORM - Environment Variables
# ============================================
# Copy this file to .env.local and fill values

# --- SUPABASE ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- APP ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="La Chapelle Internationale des Élus du Royaume"
NEXT_PUBLIC_APP_DESCRIPTION="Une Église Ouverte au Monde"

# --- JWT ---
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRES_IN=7d

# --- STRIPE ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- EMAIL (Resend) ---
RESEND_API_KEY=re_xxx
EMAIL_FROM=noreply@cier.org
EMAIL_SUPPORT=support@cier.org

# --- GOOGLE OAUTH ---
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxx

# --- FACEBOOK OAUTH ---
FACEBOOK_APP_ID=xxx
FACEBOOK_APP_SECRET=xxx

# --- WHATSAPP (Twilio / Meta) ---
WHATSAPP_API_KEY=xxx
WHATSAPP_PHONE_NUMBER=+1xxxxxxxxxx
TWILIO_ACCOUNT_SID=xxx
TWILIO_AUTH_TOKEN=xxx

# --- CLOUDINARY (Media) ---
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud
CLOUDINARY_API_KEY=xxx
CLOUDINARY_API_SECRET=xxx

# --- YOUTUBE (Live) ---
YOUTUBE_API_KEY=xxx
YOUTUBE_CHANNEL_ID=xxx

# --- OPENAI (IA Assistant) ---
OPENAI_API_KEY=sk-xxx
OPENAI_ORG_ID=org-xxx

# --- ANTHROPIC (IA Fallback) ---
ANTHROPIC_API_KEY=sk-ant-xxx

# --- PUSHER (Real-time) ---
NEXT_PUBLIC_PUSHER_APP_KEY=xxx
NEXT_PUBLIC_PUSHER_CLUSTER=eu
PUSHER_APP_ID=xxx
PUSHER_SECRET=xxx

# --- ANALYTICS ---
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-xxx
NEXT_PUBLIC_HOTJAR_ID=xxx
NEXT_PUBLIC_MIXPANEL_TOKEN=xxx

# --- FEATURE FLAGS ---
NEXT_PUBLIC_ENABLE_AI_ASSISTANT=true
NEXT_PUBLIC_ENABLE_LIVE_STREAM=true
NEXT_PUBLIC_ENABLE_LMS=true
NEXT_PUBLIC_ENABLE_COMMUNITY=true
NEXT_PUBLIC_MAINTENANCE_MODE=false
